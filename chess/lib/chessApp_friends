class _DiscoverTabState extends State<_DiscoverTab> {
  final Set<String> _sent = {};
  static const _colors = [T.violet, T.emerald, T.amber, T.crimson, Color(0xFF4FC3F7)];

  @override
  Widget build(BuildContext context) {
    if (widget.suggested.isEmpty) return const _Empty(emoji: '🌐',
        title: 'All connected', sub: 'No new suggestions right now');
    return Column(crossAxisAlignment: CrossAxisAlignment.start, children: [
      const Padding(
        padding: EdgeInsets.fromLTRB(20, 12, 20, 10),
        child: Text('People you may know',
            style: TextStyle(color: T.t2, fontSize: 13, fontWeight: FontWeight.w600,
                letterSpacing: 0.3)),
      ),
      Expanded(
        child: ListView.builder(
          padding: const EdgeInsets.fromLTRB(16, 0, 16, 32),
          itemCount: widget.suggested.length,
          itemBuilder: (_, i) {
            final u = widget.suggested[i];
            final accent = _colors[u.authUserId.codeUnitAt(0) % _colors.length];
            final sent = _sent.contains(u.authUserId);
            return Container(
              margin: const EdgeInsets.only(bottom: 10),
              height: 76,
              decoration: BoxDecoration(
                color: T.card,
                borderRadius: BorderRadius.circular(18),
                border: Border.all(color: T.divider),
              ),
              clipBehavior: Clip.antiAlias,
              child: Row(children: [
                // Image strip
                SizedBox(
                  width: 72,
                  child: u.imageUrl != null
                      ? Image.network(u.imageUrl!, fit: BoxFit.cover,
                          errorBuilder: (_, __, ___) => _AvatarFallback(user: u, accent: accent))
                      : _AvatarFallback(user: u, accent: accent),
                ),
                Expanded(
                  child: Padding(
                    padding: const EdgeInsets.symmetric(horizontal: 12),
                    child: Column(
                      crossAxisAlignment: CrossAxisAlignment.start,
                      mainAxisAlignment: MainAxisAlignment.center,
                      children: [
                        Text(u.displayName, overflow: TextOverflow.ellipsis,
                            style: const TextStyle(color: T.t1, fontSize: 14,
                                fontWeight: FontWeight.w700)),
                        const SizedBox(height: 2),
                        Text(u.shortId, style: const TextStyle(color: T.t3, fontSize: 10)),
                      ],
                    ),
                  ),
                ),
                Padding(
                  padding: const EdgeInsets.only(right: 14),
                  child: GestureDetector(
                    onTap: sent ? null : () async {
                      final err = await widget.svc.sendRequest(u.authUserId);
                      if (err != null) {
                        widget.toast(err, color: T.crimson);
                      } else {
                        setState(() => _sent.add(u.authUserId));
                        widget.toast('Request sent!', color: T.emerald);
                      }
                    },
                    child: AnimatedContainer(
                      duration: const Duration(milliseconds: 200),
                      padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 8),
                      decoration: BoxDecoration(
                        gradient: sent ? null : T.violetGrad,
                        color: sent ? T.cardHi : null,
                        borderRadius: BorderRadius.circular(10),
                        border: sent ? Border.all(color: T.divider) : null,
                        boxShadow: sent ? null : [BoxShadow(color: T.violetGlow, blurRadius: 8)],
                      ),
                      child: Row(mainAxisSize: MainAxisSize.min, children: [
                        Icon(sent ? Icons.check : Icons.add,
                            size: 13, color: sent ? T.t2 : Colors.white),
                        const SizedBox(width: 4),
                        Text(sent ? 'Sent' : 'Add',
                            style: TextStyle(
                              color: sent ? T.t2 : Colors.white,
                              fontSize: 12, fontWeight: FontWeight.w700)),
                      ]),
                    ),
                  ),
                ),
              ]),
            );
          },
        ),
      ),
    ]);
  }
}

