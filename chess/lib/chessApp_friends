class _AmbientBg extends StatelessWidget {
  final AnimationController ctrl;
  const _AmbientBg({required this.ctrl});
  @override
  Widget build(BuildContext context) => AnimatedBuilder(
    animation: ctrl,
    builder: (_, __) => CustomPaint(
      painter: _BgPaint(ctrl.value),
      size: Size(MediaQuery.of(context).size.width, MediaQuery.of(context).size.height),
    ),
  );
}

class _BgPaint extends CustomPainter {
  final double t;
  _BgPaint(this.t);
  @override
  void paint(Canvas c, Size s) {
    c.drawRect(Rect.fromLTWH(0, 0, s.width, s.height),
        Paint()..color = T.bg);
    final orbs = [
      (0.1 + 0.04 * math.sin(t * math.pi * 2),       0.08, T.violet.withOpacity(0.18), 260.0),
      (0.85 + 0.03 * math.cos(t * math.pi * 2 + 1),  0.25, T.emerald.withOpacity(0.12), 220.0),
      (0.5  + 0.05 * math.sin(t * math.pi * 2 + 2),  0.7,  T.violet.withOpacity(0.10), 300.0),
      (0.15 + 0.02 * math.cos(t * math.pi * 2 + 3),  0.85, T.emerald.withOpacity(0.08), 180.0),
    ];
    for (final o in orbs) {
      final cx = s.width  * (o.$1 as double);
      final cy = s.height * (o.$2 as double);
      c.drawCircle(Offset(cx, cy), o.$4 as double,
          Paint()..shader = RadialGradient(colors: [o.$3 as Color, Colors.transparent])
              .createShader(Rect.fromCircle(center: Offset(cx, cy), radius: o.$4 as double)));
    }
  }
  @override bool shouldRepaint(_BgPaint o) => o.t != t;
}

