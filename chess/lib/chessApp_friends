class _NotifsSheet extends StatefulWidget {
  final SocialService svc;
  final VoidCallback onRead;
  const _NotifsSheet({required this.svc, required this.onRead});
  @override State<_NotifsSheet> createState() => _NotifsSheetState();
}

class _NotifsSheetState extends State<_NotifsSheet> {
  List<AppNotification> _notifs = [];
  bool _loading = true;
  @override void initState() { super.initState(); _load(); }
  Future<void> _load() async {
    final n = await widget.svc.getNotifications();
    if (mounted) setState(() { _notifs = n; _loading = false; });
  }

  Color _c(String t) {
    switch (t) {
      case 'friend_request': return T.amber;
      case 'request_accepted': return T.emerald;
      case 'match_invite': return T.violet;
      default: return T.t2;
    }
  }
  IconData _i(String t) {
    switch (t) {
      case 'friend_request': return Icons.person_add_outlined;
      case 'request_accepted': return Icons.people_outline;
      case 'match_invite': return Icons.sports_esports_rounded;
      default: return Icons.notifications_outlined;
    }
  }
  String _ago(DateTime dt) {
    final d = DateTime.now().difference(dt);
    if (d.inMinutes < 1) return 'Now';
    if (d.inHours < 1) return '${d.inMinutes}m';
    if (d.inDays < 1) return '${d.inHours}h';
    return '${d.inDays}d';
  }

  @override
  Widget build(BuildContext context) {
    return DraggableScrollableSheet(
      initialChildSize: 0.55, maxChildSize: 0.9, minChildSize: 0.35,
      builder: (_, sc) => Container(
        decoration: const BoxDecoration(
          color: T.surface,
          borderRadius: BorderRadius.vertical(top: Radius.circular(28)),
        ),
        child: Column(children: [
          const SizedBox(height: 14),
          Container(width: 36, height: 3,
              decoration: BoxDecoration(color: T.t3, borderRadius: BorderRadius.circular(2))),
          Padding(
            padding: const EdgeInsets.fromLTRB(20, 18, 20, 14),
            child: Row(children: [
              const Text('Notifications', style: TextStyle(
                  color: T.t1, fontSize: 20, fontWeight: FontWeight.w900, letterSpacing: -0.5)),
              const Spacer(),
              GestureDetector(
                onTap: () async {
                  await widget.svc.markAllRead(); widget.onRead(); _load();
                },
                child: const Text('Mark read', style: TextStyle(color: T.t3, fontSize: 13)),
              ),
            ]),
          ),
          Expanded(
            child: _loading
                ? const Center(child: CircularProgressIndicator(color: T.violet, strokeWidth: 2))
                : _notifs.isEmpty
                    ? const _Empty(emoji: '🔔', title: 'All clear', sub: '')
                    : ListView.builder(
                        controller: sc,
                        padding: const EdgeInsets.symmetric(horizontal: 16),
                        itemCount: _notifs.length,
                        itemBuilder: (_, i) {
                          final n = _notifs[i];
                          final col = _c(n.type);
                          return Container(
                            margin: const EdgeInsets.only(bottom: 8),
                            padding: const EdgeInsets.all(14),
                            decoration: BoxDecoration(
                              color: n.isRead ? T.card : T.cardHi,
                              borderRadius: BorderRadius.circular(16),
                              border: Border.all(
                                  color: n.isRead ? T.divider : col.withOpacity(0.3)),
                            ),
                            child: Row(children: [
                              Container(
                                width: 36, height: 36,
                                decoration: BoxDecoration(
                                  color: col.withOpacity(0.12),
                                  borderRadius: BorderRadius.circular(10),
                                ),
                                child: Icon(_i(n.type), color: col, size: 17),
                              ),
                              const SizedBox(width: 12),
                              Expanded(child: Text(n.message,
                                  style: TextStyle(color: n.isRead ? T.t2 : T.t1,
                                      fontSize: 13, fontWeight: FontWeight.w500))),
                              const SizedBox(width: 8),
                              Text(_ago(n.createdAt),
                                  style: const TextStyle(color: T.t3, fontSize: 11)),
                              if (!n.isRead) ...[
                                const SizedBox(width: 6),
                                Container(width: 7, height: 7,
                                    decoration: const BoxDecoration(
                                        color: T.violet, shape: BoxShape.circle)),
                              ],
                            ]),
                          );
                        },
                      ),
          ),
        ]),
      ),
    );
  }
}

