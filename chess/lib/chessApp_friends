class ChatScreen extends StatefulWidget {
  final AppUser friend;
  final SocialService svc;
  const ChatScreen({super.key, required this.friend, required this.svc});
  @override State<ChatScreen> createState() => _ChatState();
}

class _ChatState extends State<ChatScreen> with SingleTickerProviderStateMixin {
  final _msgs = <ChatMessage>[];
  final _ctrl = TextEditingController();
  final _scroll = ScrollController();
  bool _loading = true;
  late AnimationController _bgCtrl;
  late RealtimeChannel _chan;

  @override
  void initState() {
    super.initState();
    _bgCtrl = AnimationController(vsync: this, duration: const Duration(seconds: 12))..repeat();
    _loadMsgs();
    _chan = widget.svc.subscribeMessages(widget.friend.authUserId, (msg) {
      if (mounted) { setState(() => _msgs.add(msg)); _down(); }
    });
  }

  Future<void> _loadMsgs() async {
    final m = await widget.svc.getMessages(widget.friend.authUserId);
    if (mounted) setState(() { _msgs.addAll(m); _loading = false; });
    WidgetsBinding.instance.addPostFrameCallback((_) => _down());
  }

  void _down() {
    if (_scroll.hasClients) _scroll.animateTo(
      _scroll.position.maxScrollExtent,
      duration: const Duration(milliseconds: 280), curve: Curves.easeOut);
  }

  Future<void> _send() async {
    final t = _ctrl.text.trim();
    if (t.isEmpty) return;
    _ctrl.clear();
    await widget.svc.sendMessage(widget.friend.authUserId, t);
  }

  @override
  void dispose() { _bgCtrl.dispose(); _chan.unsubscribe(); _ctrl.dispose(); _scroll.dispose(); super.dispose(); }

  static const _colors = [T.violet, T.emerald, T.amber, T.crimson, Color(0xFF4FC3F7)];
  Color get _accent => _colors[widget.friend.authUserId.codeUnitAt(0) % _colors.length];

  @override
  Widget build(BuildContext context) {
    final me = widget.svc.me;
    final u = widget.friend;
    return AnnotatedRegion<SystemUiOverlayStyle>(
      value: SystemUiOverlayStyle.light,
      child: Scaffold(
        backgroundColor: T.bg,
        body: Stack(children: [
          _AmbientBg(ctrl: _bgCtrl),
          Column(children: [
            // ── Chat header
            SafeArea(bottom: false, child: Container(
              padding: const EdgeInsets.fromLTRB(8, 8, 16, 0),
              child: Row(children: [
                IconButton(
                  icon: const Icon(Icons.arrow_back_ios_new_rounded, color: T.t1, size: 20),
                  onPressed: () => Navigator.pop(context),
                ),
                // Rectangular avatar in header
                Container(
                  width: 44, height: 44,
                  decoration: BoxDecoration(
                    borderRadius: BorderRadius.circular(12),
                    border: Border.all(color: _accent.withOpacity(0.4), width: 1.5),
                  ),
                  clipBehavior: Clip.antiAlias,
                  child: u.imageUrl != null
                      ? Image.network(u.imageUrl!, fit: BoxFit.cover,
                          errorBuilder: (_, __, ___) => _AvatarFallback(user: u, accent: _accent))
                      : _AvatarFallback(user: u, accent: _accent),
                ),
                const SizedBox(width: 10),
                Expanded(child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start, children: [
                    Text(u.displayName, style: const TextStyle(
                        color: T.t1, fontSize: 16, fontWeight: FontWeight.w800)),
                    Row(children: [
                      Container(width: 6, height: 6, decoration: BoxDecoration(
                          color: u.isOnline ? T.emerald : T.t3,
                          shape: BoxShape.circle,
                          boxShadow: u.isOnline ? [BoxShadow(color: T.emeraldGlow, blurRadius: 4)] : null)),
                      const SizedBox(width: 5),
                      Text(u.isOnline ? 'Online' : 'Offline',
                          style: TextStyle(color: u.isOnline ? T.emerald : T.t3, fontSize: 12)),
                    ]),
                  ],
                )),
                GestureDetector(
                  onTap: () {},
                  child: Container(
                    padding: const EdgeInsets.all(10),
                    decoration: BoxDecoration(
                      gradient: T.violetGrad,
                      borderRadius: BorderRadius.circular(12),
                      boxShadow: [BoxShadow(color: T.violetGlow, blurRadius: 8)],
                    ),
                    child: const Icon(Icons.sports_esports_rounded, color: Colors.white, size: 18),
                  ),
                ),
              ]),
            )),

            // ── Messages
            Expanded(
              child: _loading
                  ? const Center(child: CircularProgressIndicator(color: T.violet, strokeWidth: 2))
                  : _msgs.isEmpty
                      ? Center(child: Column(mainAxisAlignment: MainAxisAlignment.center, children: [
                          Text('♟', style: const TextStyle(fontSize: 52)),
                          const SizedBox(height: 12),
                          Text('Say hello to ${u.displayName}',
                              style: const TextStyle(color: T.t2, fontSize: 15)),
                        ]))
                      : ListView.builder(
                          controller: _scroll,
                          padding: const EdgeInsets.fromLTRB(16, 16, 16, 16),
                          itemCount: _msgs.length,
                          itemBuilder: (_, i) {
                            final msg = _msgs[i];
                            final mine = msg.senderId == me;
                            final showDate = i == 0 ||
                                _msgs[i].createdAt.day != _msgs[i - 1].createdAt.day;
                            return Column(children: [
                              if (showDate) _DChip(dt: msg.createdAt),
                              _Bubble(msg: msg, isMine: mine, accent: _accent),
                            ]);
                          },
                        ),
            ),

            // ── Input bar
            SafeArea(top: false, child: Container(
              padding: const EdgeInsets.fromLTRB(12, 10, 12, 12),
              decoration: BoxDecoration(
                color: T.surface,
                border: Border(top: BorderSide(color: T.divider)),
              ),
              child: Row(children: [
                Expanded(
                  child: Container(
                    decoration: BoxDecoration(
                      color: T.card,
                      borderRadius: BorderRadius.circular(24),
                      border: Border.all(color: T.divider),
                    ),
                    child: TextField(
                      controller: _ctrl, maxLines: null,
                      textInputAction: TextInputAction.send,
                      onSubmitted: (_) => _send(),
                      style: const TextStyle(color: T.t1, fontSize: 14),
                      decoration: const InputDecoration(
                        hintText: 'Message…', hintStyle: TextStyle(color: T.t3),
                        border: InputBorder.none,
                        contentPadding: EdgeInsets.symmetric(horizontal: 18, vertical: 12),
                      ),
                    ),
                  ),
                ),
                const SizedBox(width: 8),
                GestureDetector(
                  onTap: _send,
                  child: Container(
                    width: 48, height: 48,
                    decoration: BoxDecoration(
                      gradient: T.violetGrad,
                      shape: BoxShape.circle,
                      boxShadow: [BoxShadow(color: T.violetGlow, blurRadius: 12)],
                    ),
                    child: const Icon(Icons.send_rounded, color: Colors.white, size: 20),
                  ),
                ),
              ]),
            )),
          ]),
        ]),
      ),
    );
  }
}

class _Bubble extends StatelessWidget {
  final ChatMessage msg;
  final bool isMine;
  final Color accent;
  const _Bubble({required this.msg, required this.isMine, required this.accent});

  @override
  Widget build(BuildContext context) {
    return Align(
      alignment: isMine ? Alignment.centerRight : Alignment.centerLeft,
      child: Container(
        constraints: BoxConstraints(maxWidth: MediaQuery.of(context).size.width * 0.70),
        margin: const EdgeInsets.only(bottom: 4),
        padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 10),
        decoration: BoxDecoration(
          gradient: isMine ? LinearGradient(
            colors: [accent.withOpacity(0.22), accent.withOpacity(0.08)],
            begin: Alignment.topLeft, end: Alignment.bottomRight) : null,
          color: isMine ? null : T.cardHi,
          borderRadius: BorderRadius.only(
            topLeft: const Radius.circular(18), topRight: const Radius.circular(18),
            bottomLeft: Radius.circular(isMine ? 18 : 4),
            bottomRight: Radius.circular(isMine ? 4 : 18),
          ),
          border: Border.all(color: isMine ? accent.withOpacity(0.25) : T.divider),
        ),
        child: Column(crossAxisAlignment: CrossAxisAlignment.end, children: [
          Text(msg.content, style: const TextStyle(color: T.t1, fontSize: 14, height: 1.4)),
          const SizedBox(height: 4),
          Row(mainAxisSize: MainAxisSize.min, children: [
            Text(_fmt(msg.createdAt), style: const TextStyle(color: T.t3, fontSize: 10)),
            if (isMine) ...[
              const SizedBox(width: 4),
              Icon(msg.isRead ? Icons.done_all_rounded : Icons.done_rounded,
                  size: 12, color: msg.isRead ? T.violet : T.t3),
            ],
          ]),
        ]),
      ),
    );
  }
  String _fmt(DateTime d) =>
      '${d.hour.toString().padLeft(2,'0')}:${d.minute.toString().padLeft(2,'0')}';
}

class _DChip extends StatelessWidget {
  final DateTime dt;
  const _DChip({required this.dt});
  @override
  Widget build(BuildContext context) {
    final now = DateTime.now();
    final label = dt.day == now.day && dt.month == now.month ? 'Today'
        : dt.day == now.day - 1 ? 'Yesterday' : '${dt.day}/${dt.month}/${dt.year}';
    return Padding(
      padding: const EdgeInsets.symmetric(vertical: 12),
      child: Center(child: Container(
        padding: const EdgeInsets.symmetric(horizontal: 12, vertical: 4),
        decoration: BoxDecoration(color: T.card, borderRadius: BorderRadius.circular(10),
            border: Border.all(color: T.divider)),
        child: Text(label, style: const TextStyle(color: T.t3, fontSize: 11)),
      )),
    );
  }
}

