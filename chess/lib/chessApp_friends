class SocialService {
  final _db = Supabase.instance.client;
  String get me => _db.auth.currentUser!.id;

  // ── USERS ──────────────────────────────
  Future<AppUser?> searchUser(String q) async {
    try {
      final r = await _db
          .from('users')
          .select()
          .or('custom_id.eq.$q,auth_user_id.eq.$q,email.ilike.%$q%')
          .neq('auth_user_id', me)
          .limit(1)
          .maybeSingle();
      return r == null ? null : AppUser.fromMap(r);
    } catch (_) { return null; }
  }

  Future<AppUser?> getUser(String uid) async {
    final r = await _db.from('users').select().eq('auth_user_id', uid).maybeSingle();
    return r == null ? null : AppUser.fromMap(r);
  }

  Future<AppUser?> getSelf() async => getUser(me);

  Future<void> setOnline(bool v) async {
    await _db.from('users').update({
      'is_online': v,
      'last_seen': DateTime.now().toIso8601String(),
    }).eq('auth_user_id', me);
  }

  // ── FRIENDS ────────────────────────────
  Future<List<AppUser>> getFriends() async {
    final r = await _db.from('friends').select('friend_id').eq('user_id', me);
    if (r.isEmpty) return [];
    final ids = r.map((e) => e['friend_id'] as String).toList();
    final users = await _db.from('users').select().inFilter('auth_user_id', ids);
    return users.map((e) => AppUser.fromMap(e)).toList();
  }

  Future<List<AppUser>> getSuggested() async {
    final friendsR = await _db.from('friends').select('friend_id').eq('user_id', me);
    final sentR = await _db.from('friend_requests').select('receiver_id').eq('sender_id', me).eq('status', 'pending');
    final exclude = [
      me,
      ...friendsR.map((e) => e['friend_id'] as String),
      ...sentR.map((e) => e['receiver_id'] as String),
    ];
    final r = await _db.from('users').select()
        .not('auth_user_id', 'in', '(${exclude.map((e) => '"$e"').join(',')})')
        .limit(8);
    return r.map((e) => AppUser.fromMap(e)).toList();
  }

  Future<void> removeFriend(String friendId) async {
    await _db.from('friends').delete().eq('user_id', me).eq('friend_id', friendId);
    await _db.from('friends').delete().eq('user_id', friendId).eq('friend_id', me);
  }

  // ── REQUESTS ───────────────────────────
  Future<List<FriendRequest>> getIncoming() async {
    final r = await _db.from('friend_requests').select().eq('receiver_id', me).eq('status', 'pending');
    final reqs = r.map((e) => FriendRequest.fromMap(e)).toList();
    for (final req in reqs) req.otherUser = await getUser(req.senderId);
    return reqs;
  }

  Future<List<FriendRequest>> getSent() async {
    final r = await _db.from('friend_requests').select().eq('sender_id', me).eq('status', 'pending');
    final reqs = r.map((e) => FriendRequest.fromMap(e)).toList();
    for (final req in reqs) req.otherUser = await getUser(req.receiverId);
    return reqs;
  }

  Future<String?> sendRequest(String toId) async {
    final ex = await _db.from('friend_requests').select()
        .or('and(sender_id.eq.$me,receiver_id.eq.$toId),and(sender_id.eq.$toId,receiver_id.eq.$me)')
        .maybeSingle();
    if (ex != null) return 'Request already exists';
    final af = await _db.from('friends').select().eq('user_id', me).eq('friend_id', toId).maybeSingle();
    if (af != null) return 'Already friends';
    await _db.from('friend_requests').insert({'sender_id': me, 'receiver_id': toId});
    await _db.from('notifications').insert({
      'user_id': toId, 'type': 'friend_request',
      'message': 'You have a new friend request', 'from_user_id': me,
    });
    return null;
  }

  Future<void> acceptRequest(String reqId, String senderId) async {
    await _db.from('friend_requests').update({'status': 'accepted'}).eq('id', reqId);
    await _db.from('friends').upsert([
      {'user_id': me, 'friend_id': senderId},
      {'user_id': senderId, 'friend_id': me},
    ]);
    await _db.from('notifications').insert({
      'user_id': senderId, 'type': 'request_accepted',
      'message': 'Your friend request was accepted!', 'from_user_id': me,
    });
  }

  Future<void> rejectRequest(String reqId) async =>
      _db.from('friend_requests').update({'status': 'rejected'}).eq('id', reqId);

  Future<void> cancelRequest(String reqId) async =>
      _db.from('friend_requests').delete().eq('id', reqId);

  // ── MESSAGES ───────────────────────────
  Future<List<ChatMessage>> getMessages(String otherId) async {
    final r = await _db.from('messages').select()
        .or('and(sender_id.eq.$me,receiver_id.eq.$otherId),and(sender_id.eq.$otherId,receiver_id.eq.$me)')
        .order('created_at');
    // Mark as read
    await _db.from('messages').update({'is_read': true})
        .eq('sender_id', otherId).eq('receiver_id', me).eq('is_read', false);
    return r.map((e) => ChatMessage.fromMap(e)).toList();
  }

  Future<void> sendMessage(String toId, String content) async {
    await _db.from('messages').insert({
      'sender_id': me, 'receiver_id': toId, 'content': content,
    });
  }

  Future<int> getUnreadCount(String fromId) async {
    final r = await _db.from('messages').select()
        .eq('sender_id', fromId).eq('receiver_id', me).eq('is_read', false);
    return r.length;
  }

  RealtimeChannel subscribeMessages(String otherId, Function(ChatMessage) onNew) {
    return _db.channel('chat_${me}_$otherId')
        .onPostgresChanges(
          event: PostgresChangeEvent.insert,
          schema: 'public', table: 'messages',
          callback: (p) {
            final msg = ChatMessage.fromMap(p.newRecord);
            if ((msg.senderId == me && msg.receiverId == otherId) ||
                (msg.senderId == otherId && msg.receiverId == me)) {
              onNew(msg);
            }
          },
        ).subscribe();
  }

  // ── NOTIFICATIONS ──────────────────────
  Future<List<AppNotification>> getNotifications() async {
    final r = await _db.from('notifications').select()
        .eq('user_id', me).order('created_at', ascending: false).limit(30);
    return r.map((e) => AppNotification.fromMap(e)).toList();
  }

  Future<void> markAllRead() async =>
      _db.from('notifications').update({'is_read': true}).eq('user_id', me);

  RealtimeChannel subscribeNotifications(Function(AppNotification) onNew) {
    return _db.channel('notif_$me')
        .onPostgresChanges(
          event: PostgresChangeEvent.insert,
          schema: 'public', table: 'notifications',
          filter: PostgresChangeFilter(
            type: PostgresChangeFilterType.eq, column: 'user_id', value: me),
          callback: (p) => onNew(AppNotification.fromMap(p.newRecord)),
        ).subscribe();
  }

  RealtimeChannel subscribeRequests(Function() onChange) {
    return _db.channel('req_$me')
        .onPostgresChanges(
          event: PostgresChangeEvent.all,
          schema: 'public', table: 'friend_requests',
          callback: (_) => onChange(),
        ).subscribe();
  }
}

