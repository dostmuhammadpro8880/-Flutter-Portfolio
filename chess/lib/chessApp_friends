  void initState() {
    super.initState();
    _ac = AnimationController(vsync: this, duration: const Duration(milliseconds: 220));
    _expand = CurvedAnimation(parent: _ac, curve: Curves.easeOutCubic);
  }
  @override void dispose() { _ac.dispose(); super.dispose(); }

  void _toggle() {
    setState(() => _open = !_open);
    _open ? _ac.forward() : _ac.reverse();
  }

  // Deterministic color per user
  static const _colors = [T.violet, T.emerald, T.amber, T.crimson, Color(0xFF4FC3F7)];
